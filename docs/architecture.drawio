        </mxCell>
        <mxCell id="g_store" value="Storage (BackendStack)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f1f8ec;strokeColor=#9cc079;dashed=1;verticalAlign=top;align=left;spacingLeft=8;fontColor=#4f6b0e;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1240" y="40" width="320" height="650" as="geometry" />
        </mxCell>
        <mxCell id="browser" value="Browser&#10;React + Vite SPA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;strokeColor=#11161d;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="cf" value="CloudFront&#10;Distribution + ACM cert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;strokeColor=#5A2FB0;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="90" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="clientbucket" value="Client S3 bucket&#10;(private, OAC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=#4F6B0E;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="70" y="190" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="api" value="API Lambda&#10;(Function URL, Node 20)&#10;presign · status · trigger burn" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F58536;strokeColor=#C05E10;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="orch" value="Orchestrator Lambda&#10;(Docker, ffmpeg)&#10;decode → segment → fan-out → merge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F58536;strokeColor=#C05E10;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="90" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="worker" value="Worker Lambda  (x N parallel)&#10;(Docker, whisper.cpp)&#10;chunk → transcribe → cues" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F58536;strokeColor=#C05E10;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="210" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="burn" value="Burn Lambda&#10;(Docker, ffmpeg + libass)&#10;soft mux / hard burn-in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F58536;strokeColor=#C05E10;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="520" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="uploads" value="Uploads S3&#10;(source videos)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=#4F6B0E;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1270" y="90" width="260" height="60" as="geometry" />
        </mxCell>

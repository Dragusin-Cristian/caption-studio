<mxfile host="app.diagrams.net" type="device">
  <diagram name="caption-studio architecture" id="caption-studio">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="g_host" value="Static Hosting — ClientStack" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f0f4ff;strokeColor=#9aa8d8;dashed=1;verticalAlign=top;align=left;spacingLeft=8;fontColor=#3a4a7a;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="40" width="300" height="240" as="geometry" />
        </mxCell>
        <mxCell id="g_trans" value="Transcription pipeline (event-driven)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff4ec;strokeColor=#e0a878;dashed=1;verticalAlign=top;align=left;spacingLeft=8;fontColor=#9a5a1a;fontSize=13;fontStyle=1;" vertex="1" parent="1">

        <mxCell id="results" value="Results S3&#10;(cues JSON + burned mp4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7AA116;strokeColor=#4F6B0E;fontColor=#ffffff;fontStyle=1;fontSize=12;" vertex="1" parent="1">
